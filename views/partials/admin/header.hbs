<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          colors: {
            sidebar: '#EDF1F9',
            brandBlue: '#0047FF',
            cardBg: '#F5F8FF',
            cardBorder: '#A5C0FF',
            lightBlue: '#DDF0FF'
          }
        }
      }
    }
  </script>
</head>

<body class="bg-white text-gray-800 font-sans antialiased h-screen flex overflow-hidden">

  <div id="sidebarOverlay" class="fixed inset-0 bg-gray-900/50 z-40 hidden lg:hidden transition-opacity"></div>

  <aside id="sidebar"
    class="fixed inset-y-0 left-0 z-50 w-64 bg-sidebar h-full flex flex-col border-r border-gray-200 transform -translate-x-full lg:translate-x-0 lg:static transition-transform duration-300 ease-in-out shrink-0">
    <div class="h-20 flex items-center justify-between px-8">
      <h1 class="text-2xl font-black text-gray-500 tracking-wider">ARMOR</h1>
      <button id="closeSidebarBtn" class="lg:hidden p-2 text-gray-500 hover:bg-gray-200 rounded-lg">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <nav class="flex-1 mt-4 space-y-2 overflow-y-auto px-4 pb-4">
      <a href="/admin/"
        class="flex items-center gap-4 bg-brandBlue text-white px-4 py-3.5 rounded-xl shadow-md font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z">
          </path>
        </svg>
        DASHBOARD
      </a>

      <a href="/admin/products"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
        </svg>
        ALL PRODUCTS
      </a>

      <a href="/admin/users"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z">
          </path>
        </svg>
        CUSTOMERS
      </a>

      <a href="/admin/orders"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4">
          </path>
        </svg>
        ORDER LIST
      </a>

      <a href="/admin/coupons"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
          </path>
        </svg>
        COUPON
      </a>

      <a href="/admin/categories"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
          </path>
        </svg>
        CATEGORY
      </a>

      <a href="/admin/offers"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01">
          </path>
        </svg>
        OFFER
      </a>

      <a href="/admin/banners"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z">
          </path>
        </svg>
        BANNER
      </a>

      <a href="/admin/sales-report"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide mt-4 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
        </svg>
        Sales Report
      </a>
    </nav>

    <div class="p-4 mb-4">
      <a href="/admin/logout"
        class="flex items-center gap-4 text-gray-900 px-4 py-3.5 hover:bg-gray-200 rounded-xl font-bold text-sm tracking-wide transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
        </svg>
        LOGOUT
      </a>
    </div>
  </aside>


  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Get the current page URL path (e.g., "/admin/products")
      const currentPath = window.location.pathname;

      // 2. Select all the links inside the sidebar
      const navLinks = document.querySelectorAll('#sidebar a');

      // 3. Define the styling classes
      const activeClasses = ['bg-brandBlue', 'text-white', 'shadow-md'];
      const inactiveClasses = ['text-gray-900', 'hover:bg-gray-200'];

      navLinks.forEach(link => {
        // Get the href attribute of the link
        const linkPath = link.getAttribute('href');

        // 4. Reset every link to the inactive state first
        link.classList.remove(...activeClasses);
        link.classList.add(...inactiveClasses);

        // 5. Check if the current page path matches the link's href
        // We check for an exact match, or an exact match with a trailing slash
        if (currentPath === linkPath || currentPath === linkPath + '/') {
          // Apply the active blue styling
          link.classList.remove(...inactiveClasses);
          link.classList.add(...activeClasses);
        }
      });
    });
  </script>