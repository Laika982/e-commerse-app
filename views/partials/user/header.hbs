  <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-wrap items-center justify-between gap-4">
    <a href="#" class="flex items-center space-x-2">
      <div class="w-8 h-8 bg-emerald-500 rounded flex items-center justify-center text-white font-bold text-xl">T</div>
      <span class="text-xl font-bold tracking-tight">TeeSpace</span>
    </a>

    <div
      class="hidden md:flex flex-1 max-w-lg items-center bg-white border border-gray-200 rounded-full pl-5 pr-1 py-1 shadow-sm">
      <svg class="w-4 h-4 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <input type="text" placeholder="What are you looking for?" class="flex-1 outline-none text-sm bg-transparent">
      <button
        class="bg-black text-white px-6 py-2 rounded-full text-sm font-medium hover:bg-gray-800 transition-colors">Search</button>
    </div>

    <div class="flex items-center space-x-4 md:space-x-6">
      <div class="hidden sm:flex items-center space-x-2">
        <a href="/login"
          class="text-sm font-medium hover:text-emerald-500 px-4 py-2 rounded-full border border-gray-200">Log
          In</a>
        <a href="/signup" class="text-sm font-medium bg-black text-white px-4 py-2 rounded-full hover:bg-gray-800">Sign
          Up</a>
      </div>

      <div class="flex items-center space-x-4">
