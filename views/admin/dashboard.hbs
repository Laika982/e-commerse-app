<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- Calendar Logic ---
        const calendarBtn = document.getElementById('calendarBtn');
        const calendarPopup = document.getElementById('calendarPopup');
        const cancelBtn = document.getElementById('cancelDateBtn');
        const applyBtn = document.getElementById('applyDateBtn');

        const toggleCalendar = (e) => {
            e.stopPropagation();
            calendarPopup.classList.toggle('hidden');
        };

        const closeCalendar = () => {
            if (!calendarPopup.classList.contains('hidden')) {
                calendarPopup.classList.add('hidden');
            }
        };

        calendarBtn.addEventListener('click', toggleCalendar);
        cancelBtn.addEventListener('click', closeCalendar);
        applyBtn.addEventListener('click', closeCalendar);

        // --- Sidebar Mobile Toggle Logic ---
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const closeSidebarBtn = document.getElementById('closeSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        const toggleSidebar = () => {
            const isClosed = sidebar.classList.contains('-translate-x-full');
            if (isClosed) {
                sidebar.classList.remove('-translate-x-full');
                sidebarOverlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('-translate-x-full');
                sidebarOverlay.classList.add('hidden');
            }
        };

        mobileMenuBtn.addEventListener('click', toggleSidebar);
        closeSidebarBtn.addEventListener('click', toggleSidebar);
        sidebarOverlay.addEventListener('click', toggleSidebar);

        // --- Graph Filter Button Animation Logic ---
        const graphFilterBtns = document.querySelectorAll('.graph-filter-btn');

        graphFilterBtns.forEach(btn => {
            btn.addEventListener('click', function () {
                // Reset all buttons to inactive state
                graphFilterBtns.forEach(b => {
                    b.classList.remove('bg-brandBlue', 'text-white');
                    b.classList.add('text-gray-600', 'hover:bg-gray-100');
                });

                // Set the clicked button to active state
                this.classList.remove('text-gray-600', 'hover:bg-gray-100');
                this.classList.add('bg-brandBlue', 'text-white');
            });
        });

        // --- Global Click Outside (Close Popups) ---
        document.addEventListener('click', (e) => {
            // Close Calendar if clicked outside
            if (!calendarPopup.contains(e.target) && !calendarBtn.contains(e.target)) {
                closeCalendar();
            }
        });
    });
</script>
