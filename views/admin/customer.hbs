{{> admin/header}}

<main class="flex-1 overflow-y-auto p-6">
    <div class="mb-6 flex justify-between items-center border-b pb-4">
        <h2 class="text-2xl font-bold text-gray-800">Customers</h2>
        <form action="/admin/users" method="get" class="flex gap-2">
            <input type="text" name="search" value="{{search}}" placeholder="Search customers..."
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-sm w-64">
            <button type="submit"
                class="bg-blue-600 font-semibold text-white px-5 py-2 rounded-lg hover:bg-blue-700 transition shadow-sm">Search</button>
        </form>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-100 border-b border-gray-200">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-gray-600 uppercase tracking-wider">Name</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-600 uppercase tracking-wider">Email</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-600 uppercase tracking-wider">Phone / GoogleID</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-600 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-600 uppercase tracking-wider text-right">Action
                    </th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                {{#each data}}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">{{this.name}}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">{{this.email}}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{this.phone}}{{this.googleId}}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        {{#if this.isBlocked}}
                        <span
                            class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-red-100 text-red-700 border border-red-200">Blocked</span>
                        {{else}}
                        <span
                            class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-green-100 text-green-700 border border-green-200">Active</span>
                        {{/if}}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        {{#if this.isBlocked}}
                        <a href="/admin/unblockCustomer?id={{this._id}}"
                            class="inline-block bg-green-500 hover:bg-green-600 text-white font-medium px-4 py-2 rounded-lg transition-colors shadow-sm">Unblock</a>
                        {{else}}
                        <a href="/admin/blockCustomer?id={{this._id}}"
                            class="inline-block bg-red-500 hover:bg-red-600 text-white font-medium px-4 py-2 rounded-lg transition-colors shadow-sm">Block</a>
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        {{#unless data.length}}
        <div class="px-6 py-8 text-center text-gray-500">
            No customers found.
        </div>
        {{/unless}}
    </div>

    {{#if pages.length}}
    <div class="mt-8 flex justify-center">
        <nav class="inline-flex rounded-lg shadow-sm -space-x-px" aria-label="Pagination">
            {{#each pages}}
            <a href="/admin/users?page={{this.page}}&search={{../search}}"
                class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium {{#if this.active}}z-10 bg-blue-50 border-blue-500 text-blue-700{{else}}text-gray-700 hover:bg-gray-50{{/if}} first:rounded-l-lg last:rounded-r-lg transition-colors">
                {{this.page}}
            </a>
            {{/each}}
        </nav>
    </div>
    {{/if}}
</main>
</div>

{{> admin/footer}}