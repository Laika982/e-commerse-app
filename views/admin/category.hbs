{{>admin/header}}

<div class="flex-1 flex flex-col h-full min-w-0">

    <header
        class="h-21 bg-white border-b border-gray-200 flex items-center justify-between px-6 lg:px-10 py-5 flex-shrink-0 z-10 shadow-sm relative">

        <div class="flex items-center gap-4">
            <button class="lg:hidden text-gray-600 focus:outline-none">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16">
                    </path>
                </svg>
            </button>
            <h1 class="text-[28px] font-semibold text-[#576B8B]">Category</h1>
        </div>

        <div class="flex items-center gap-4 lg:gap-6">
            <div class="relative hidden sm:block">
                <input type="text" placeholder="Search..."
                    class="pl-5 pr-12 py-2.5 w-64 lg:w-[280px] border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-1 focus:ring-blue-500 bg-white placeholder-gray-400">
                <svg class="w-5 h-5 text-gray-400 absolute right-4 top-2.5" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>

            <div class="flex items-center gap-3">
                <img src="https://i.pravatar.cc/150?img=11" alt="User avatar"
                    class="w-10 h-10 rounded-full object-cover ring-2 ring-gray-100">

                <button
                    class="relative w-10 h-10 rounded-full bg-[#EBF4FF] flex items-center justify-center text-[#2563EB] hover:bg-blue-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9">
                        </path>
                    </svg>
                    <span
                        class="absolute -top-1 -right-1 bg-[#3B82F6] text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full border border-white">21</span>
                </button>

                <button
                    class="relative w-10 h-10 rounded-full bg-[#EBF4FF] flex items-center justify-center text-[#2563EB] hover:bg-blue-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03-8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z">
                        </path>
                    </svg>
                    <span
                        class="absolute -top-1 -right-1 bg-[#3B82F6] text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full border border-white">53</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-1 overflow-y-auto flex flex-col relative z-0">
        <div class="flex-1 p-6 lg:p-10 w-full max-w-[1400px] mx-auto">

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
                <div>
                    <h2 class="text-2xl font-bold text-gray-800 mb-1">Categories</h2>
                    <div class="flex items-center text-sm">
                        <a href="#" class="text-blue-600 hover:underline">Dashboard</a>
                        <span class="mx-2 text-gray-400">›</span>
                        <span class="text-gray-500">Categories</span>
                    </div>
                </div>
                <a href="/admin/addCategory">
                    <button
                        class="bg-[#0C5CE9] hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg text-sm font-medium flex items-center transition-colors shadow-sm self-start sm:self-auto">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4">
                            </path>
                        </svg>
                        Add Category
                    </button>
                </a>
            </div>

            <div class="mb-4">
                <button
                    class="bg-white border border-gray-200 text-gray-600 px-4 py-2 rounded-lg text-sm font-medium flex items-center hover:bg-gray-50 transition-colors">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4">
                        </path>
                    </svg>
                    Filters
                </button>
            </div>

            <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden flex flex-col w-full">
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse min-w-[800px]">
                        <thead>
                            <tr class="bg-[#F9FAFB] border-b border-gray-100">
                                <th class="py-4 pl-6 pr-3 w-12">
                                    <input type="checkbox"
                                        class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                                </th>
                                <th class="py-4 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">
                                    <div class="flex items-center">
                                        Category
                                        <svg class="w-4 h-4 ml-1 text-gray-400" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </th>
                                <th class="py-4 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">
                                    <div class="flex items-center">
                                        Sales
                                        <svg class="w-4 h-4 ml-1 text-gray-400" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </th>
                                <th class="py-4 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">
                                    <div class="flex items-center">
                                        Stock
                                        <svg class="w-4 h-4 ml-1 text-gray-400" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </th>
                                <th class="py-4 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">
                                    <div class="flex items-center">
                                        Added
                                        <svg class="w-4 h-4 ml-1 text-gray-400" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </th>
                                <th
                                    class="py-4 px-6 text-xs font-semibold text-gray-600 uppercase tracking-wider text-right w-32">
                                    Action
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {{#if cat.length}}
                            {{#each cat}}
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="py-4 pl-6 pr-3">
                                    <input type="checkbox"
                                        class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                                </td>
                                <td class="py-4 px-4">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-10 h-10 bg-gray-200 rounded-md overflow-hidden flex items-center justify-center">
                                            {{#if this.image}}
                                            <img src="/uploads/{{this.image}}" alt="{{this.category_name}}"
                                                class="w-full h-full object-cover">
                                            {{else}}
                                            <span class="text-xs text-gray-400">No Img</span>
                                            {{/if}}
                                        </div>
                                        <span class="text-sm font-medium text-gray-800">{{this.category_name}}</span>
                                    </div>
                                </td>
                                <td class="py-4 px-4 text-sm text-gray-600">{{#if
                                    this.sales_quantity}}{{this.sales_quantity}}{{else}}0{{/if}}</td>
                                <td class="py-4 px-4 text-sm text-gray-600">{{#if
                                    this.stock_quantity}}{{this.stock_quantity}}{{else}}0{{/if}}</td>
                                <td class="py-4 px-4 text-sm text-gray-600">{{this.createdAt}}</td>
                                <td class="py-4 px-6 text-right">
                                    <div class="flex justify-end gap-3 text-gray-400">
                                        <button class="hover:text-gray-600 transition-colors" title="View"><svg
                                                class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z">
                                                </path>
                                            </svg></button>
                                        <a href="/admin/editCategory?id={{this._id}}"
                                            class="hover:text-blue-600 transition-colors" title="Edit"><svg
                                                class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                                                </path>
                                            </svg></a>
                                        <a href="/admin/deleteCategory?id={{this._id}}"
                                            class="hover:text-red-600 transition-colors" title="Delete"
                                            onclick="return confirm('Are you sure you want to delete this category?');"><svg
                                                class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                                </path>
                                            </svg></a>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                            {{else}}
                            <tr>
                                <td colspan="6" class="py-8 text-center text-gray-500">
                                    No categories found. Adding a category will populate this list.
                                </td>
                            </tr>
                            {{/if}}
                        </tbody>
                    </table>
                </div>

                <div class="flex items-center justify-between px-6 py-4 border-t border-gray-100 bg-white w-full">
                    <p class="text-sm text-gray-500">
                        Page {{currentPage}} of {{totalPages}} (Total {{totalCategories}} categories)
                    </p>
                    <div class="flex items-center gap-2">
                        {{#if pagination.hasPrev}}
                        <a href="?page={{pagination.prevPage}}"
                            class="w-8 h-8 flex items-center justify-center rounded bg-indigo-50 text-indigo-600 hover:bg-indigo-100 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 19l-7-7 7-7"></path>
                            </svg>
                        </a>
                        {{/if}}

                        <button
                            class="w-8 h-8 flex items-center justify-center rounded bg-blue-600 text-white font-medium shadow-sm">
                            {{currentPage}}
                        </button>

                        {{#if pagination.hasNext}}
                        <a href="?page={{pagination.nextPage}}"
                            class="w-8 h-8 flex items-center justify-center rounded bg-indigo-50 text-indigo-600 hover:bg-indigo-100 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7">
                                </path>
                            </svg>
                        </a>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>

        {{>admin/footer}}